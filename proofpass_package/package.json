{
  "name": "proofpass-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node ./scripts/clean-next.cjs",
    "dev": "npm run clean && node --require ./scripts/node-localstorage-shim.cjs ./node_modules/next/dist/bin/next dev",
    "build": "npm run clean && node --require ./scripts/node-localstorage-shim.cjs ./node_modules/next/dist/bin/next build",
    "start": "node --require ./scripts/node-localstorage-shim.cjs ./node_modules/next/dist/bin/next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
